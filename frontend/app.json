{
  "expo": {
    "name": "PIMTO",
    "slug": "PIMTO",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo_PIMTO.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo_PIMTO.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_PIMTO.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.PIMTO"
    },
    "web": {
      "favicon": "./assets/logo_PIMTO.png"
    },
    "plugins": [
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "a4760cca-0098-4cfd-b92c-89019c11f65d"
      }
    }
  }
}
